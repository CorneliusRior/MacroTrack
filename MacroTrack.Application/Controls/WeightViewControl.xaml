<local:ControlBase x:Class="MacroTrack.AppLibrary.Controls.WeightViewControl"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                   xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
                   xmlns:local="clr-namespace:MacroTrack.AppLibrary.Controls"
                   xmlns:graphs="clr-namespace:MacroTrack.AppLibrary.Graphs"
                   mc:Ignorable="d" 
                   d:DesignHeight="450" d:DesignWidth="450">
    <UserControl.Resources>
        <CollectionViewSource x:Key="SortedEntries" Source="{Binding Entries}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="Time" Direction="Descending"/>
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
    </UserControl.Resources>
    
    <Border Background="{DynamicResource PanelBackGroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <Border Background="{DynamicResource AppBackGroundBrush}" Grid.Row="1" Margin="5">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="WeightItems" ItemsSource="{Binding Source={StaticResource SortedEntries}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <local:WeightEntryCard Entry="{Binding}"
                                                           TimeFormat="{Binding DataContext.TimeFormat, RelativeSource={RelativeSource AncestorType=local:WeightViewControl}}"
                                                           UnitLabel="{Binding DataContext.UnitLabel, RelativeSource={RelativeSource AncestorType=local:WeightViewControl}}"
                                                           Margin="2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
                
                <Button x:Name="buttonDelete"
                        Content="Delete Selected"
                        Style="{DynamicResource Button.Delete}"
                        HorizontalAlignment="Right"
                        Click="buttonDelete_Click"
                        Grid.Row="2"/>
            </Grid>
            
            <Border BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="{DynamicResource ButtonBorderThickness}"
                    Margin="5"
                    Grid.Row="1">
                <graphs:MTLineChart x:Name="WeightGraph"
                                    SeriesSet="{Binding GraphSeriesSet}"
                                    XStart="{Binding GraphStartTime}"
                                    XEnd="{Binding GraphEndTime}"
                                    YAxisSuffix="{Binding UnitLabel}" 
                                    Settings="{Binding GraphSettings}"
                                    ShowZero="False"/>
            </Border>

        </Grid>
    </Border>
</local:ControlBase>
