<UserControl x:Class="MacroTrack.AppLibrary.Controls.LabelledNumericInput"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MacroTrack.AppLibrary.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="30" d:DesignWidth="200">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBox Style="{DynamicResource TextBox.NumericInteger}" 
                 Text="{Binding Value, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Width="{Binding InputWidth, ElementName=Root}"
                 x:Name="PART_tb" 
                 Margin="2"
                 Grid.Column="0"/>
        <Label Content="{Binding UnitLabelText, ElementName=Root}"
               x:Name="PART_UnitLabel"
               Margin="0"
               Grid.Column="1"/>
        <Label Content="{Binding LabelText, ElementName=Root}" 
               x:Name="PART_label"
               Grid.Column="2"/>

    </Grid>
</UserControl>
