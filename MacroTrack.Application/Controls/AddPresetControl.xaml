<local:ControlBase x:Class="MacroTrack.AppLibrary.Controls.AddPresetControl"   
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                   xmlns:local="clr-namespace:MacroTrack.AppLibrary.Controls"
                   mc:Ignorable="d" 
                   d:DesignHeight="350" d:DesignWidth="600">
    <Border Background="{DynamicResource PanelBackGroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Label Content="Add New Preset"
                   Style="{DynamicResource Label.Title}"
                   Grid.Row="0"/>
            
            <!--Content Grid-->
            <Border Margin="5" Grid.Row="1"> <!--This is here for padding or margin &c.-->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!--First Row-->
                    <Label Content="Preset Name:" Grid.Row="0" Grid.Column="0"/>
                    <TextBox x:Name="tbPresetName" MinWidth="200" Grid.Row="0" Grid.Column="1"/>
                    <Grid Grid.Row="0" Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Label Content="Amount (x1):" 
                               HorizontalAlignment="Right" 
                               Grid.Row="0" Grid.Column="0"/>
                        <TextBox x:Name="tbWeight" 
                                 Style="{DynamicResource TextBox.Numeric}" 
                                 Grid.Row="0" Grid.Column="1"/>
                        <ComboBox x:Name="cbUnit"
                                  Width="50"
                                  Template="{DynamicResource MTComboBoxTemplate}"
                                  Grid.Column="2"/>

                    </Grid>
                    
                    <!--Second Row-->
                    <Label Content="Preset Category" Grid.Row="1" Grid.Column="0"/>
                    <ComboBox x:Name="cbCategory" 
                              Template="{DynamicResource MTComboBoxTemplate}"
                              Grid.Row="1" Grid.Column="1"/>
                    
                    <!--Third Row-->
                    <StackPanel Orientation="Horizontal" Grid.Row="2"                                 
                                Grid.Column="0" Grid.ColumnSpan="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Calories (Kcal):" Grid.Column="0"/>
                            <TextBox x:Name="tbCal" 
                                     Style="{DynamicResource TextBox.Numeric}" 
                                     Grid.Column="1"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Protein (g):" 
                                   Grid.Column="0"/>
                            <TextBox x:Name="tbPro" 
                                     Style="{DynamicResource TextBox.Numeric}" 
                                     Grid.Column="1"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Carbs (g):" Grid.Column="0"/>
                            <TextBox x:Name="tbCar" 
                                     Style="{DynamicResource TextBox.Numeric}" 
                                     Grid.Column="1"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Fat (g):" Grid.Column="0"/>
                            <TextBox x:Name="tbFat" 
                                     Style="{DynamicResource TextBox.Numeric}" 
                                     Grid.Column="1"/>
                        </Grid>

                    </StackPanel>

                    <!--Fourth & Fifth Row-->
                    <Label Content="Notes:" Grid.Row="3"/>
                    <TextBox Style="{DynamicResource TextBox.MultiLine}" 
                             Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="5"/>


                </Grid>
            </Border>

            <StackPanel Style="{DynamicResource StackPanel.Footer}"
                        Grid.Row="2">
                <Button x:Name="buttonCancel"
                        Content="Cancel"
                        Click="buttonCancel_Click"/>
                <Button x:Name="buttonClear"
                        Content="Clear"
                        Click="buttonClear_Click"/>
                <Button x:Name="buttonAdd"
                        Content="Add"
                        Click="buttonAdd_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</local:ControlBase>
