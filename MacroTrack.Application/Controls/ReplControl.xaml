<local:ControlBase x:Class="MacroTrack.AppLibrary.Controls.ReplControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MacroTrack.AppLibrary.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="{DynamicResource PanelBackGroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBox Grid.Row="0"
                     Name="tbOutput"
                     IsReadOnly="True"
                     Style="{StaticResource TextBox.Repl}"
                     Padding="5"
                     Margin="5,5,5,0"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Name="tbInput"
                         KeyDown="tbInput_KeyDown"
                         Style="{StaticResource TextBox.ReplInput}"
                         Padding="5"
                         Margin="5"/>

                <Button Grid.Column="1"
                        Content="Enter"
                        Name="ButtonEnter"
                        Click="ButtonEnter_Click"/>

            </Grid>

        </Grid>
    </Border>
</local:ControlBase>
