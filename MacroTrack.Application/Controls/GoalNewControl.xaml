<local:ControlBase x:Class="MacroTrack.AppLibrary.Controls.GoalNewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                   xmlns:conv="clr-namespace:MacroTrack.AppLibrary.Converters"
             xmlns:local="clr-namespace:MacroTrack.AppLibrary.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="500">
    <local:ControlBase.Resources>
        <conv:AndBoolConverter x:Key="AndBool"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
    </local:ControlBase.Resources>
    <Border Background="{DynamicResource PanelBackGroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <TextBlock Text="Add New Goal" Style="{DynamicResource TextBlock.MidTitle}"/>
            </Grid>

            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden" Grid.Row="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto" MinHeight="100"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Orientation="Horizontal" Grid.Row="0">
                        <Label Content="Goal name:" Target="{Binding ElementName=tbGoalName}"/>
                        <TextBox x:Name="tbGoalName" Text="{Binding GoalName}" MinWidth="200"/>
                    </WrapPanel>
                    <WrapPanel Orientation="Horizontal" Grid.Row="1">
                        <Label Content="Goal type:" Target="{Binding ElementName=cbType}"/>
                        <ComboBox x:Name="cbType" Template="{DynamicResource MTComboBoxTemplate}" MinWidth="150"/>
                    </WrapPanel>

                    <WrapPanel Orientation="Horizontal" Grid.Row="2">
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Calories:"/>
                            <local:SpinBox Value="{Binding Calories}"
                                           Step="100" SmallStep="10"
                                           Width="64" ButtonWidth="12" FormatString="0.##" Margin="5"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="Set Minimum" IsChecked="{Binding MinCalEnabled, Mode=TwoWay}"/>
                            <local:SpinBox Value="{Binding MinCal, Mode=TwoWay}" IsEnabled="{Binding MinCalEnabled}"
                                           Width="64" ButtonWidth="12" FormatString="0.##" Margin="5"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="Set Maximum" IsChecked="{Binding MaxCalEnabled, Mode=TwoWay}"/>
                            <local:SpinBox Value="{Binding MaxCal, Mode=TwoWay}" IsEnabled="{Binding MaxCalEnabled}"
                                           Width="64" ButtonWidth="12" FormatString="0.##" Margin="5"/>
                        </StackPanel>
                    </WrapPanel>
                    
                    <!--Sliders-->
                    <Grid HorizontalAlignment="Center" Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!--Each slider is its own grid w/ data context-->
                        <!--Protein:-->
                        <local:GoalNewSlider DataContext="{Binding P}" Grid.Column="0"/>
                        <local:GoalNewSlider DataContext="{Binding C}" Grid.Column="1"/>
                        <local:GoalNewSlider DataContext="{Binding F}" Grid.Column="2"/>
                    </Grid>

                    <Label Content="Notes:" Grid.Row="4"/>
                    <TextBox x:Name="tbNotes" Text="{Binding Notes}" TextWrapping="Wrap" VerticalContentAlignment="Top" Grid.Row="5"/>
                    
                </Grid>
            </ScrollViewer>

            <StackPanel Style="{DynamicResource StackPanel.Footer}" Grid.Row="2">
                <Button x:Name="Cancel" Content="Cancel" Command="{Binding CancelCommand}"/>
                <Button x:Name="Add" Content="Add" Command="{Binding AddCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</local:ControlBase>
