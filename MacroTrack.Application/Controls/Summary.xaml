<local:ControlBase x:Class="MacroTrack.AppLibrary.Controls.Summary" 
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                   xmlns:local="clr-namespace:MacroTrack.AppLibrary.Controls"
                   xmlns:models="clr-namespace:MacroTrack.AppLibrary.Models"
                   Height="300" Width="700">
    <Border Background="{DynamicResource PanelBackGroundBrush}">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--First row (Summary)-->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="14*"/> <!--Feel free to adjust this-->
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                
                <!--Top/banner-->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.ColumnSpan="7">
                    <Label x:Name="labelGoal"  
                           Content="{Binding CurrentSummary.GoalName, RelativeSource={RelativeSource AncestorType=local:ControlBase}, TargetNullValue='No Goal Selected'}"
                           Style="{DynamicResource Label.Title}"/>
                    <ComboBox x:Name="cbTimeFrame"
                              Template="{DynamicResource MTComboBoxTemplate}"
                              ItemsSource="{x:Static models:SummaryTimeFrameValues.List}"
                              DisplayMemberPath="Display"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding TimeFrame, RelativeSource={RelativeSource AncestorType=local:ControlBase}, Mode=TwoWay}"
                              Width="125"/>
                </StackPanel>
                
                <!--Ordered in Columns, do each row in the column before moving onto next column-->
                <!--Column 0 MacroLabels:-->
                <Label Content="Calories:" Grid.Row="2" Grid.Column="0" Padding="0"/>
                <Label Content="Protein:" Grid.Row="3" Grid.Column="0" Padding="0"/>
                <Label Content="Carbs:" Grid.Row="4" Grid.Column="0" Padding="0"/>
                <Label Content="Fat:" Grid.Row="5" Grid.Column="0" Padding="0"/>
                
                <!--Column 1 MacroBars:-->
                
                <!--Column 2 Actual-->
                <Label Content="{Binding CurrentSummary.Actual.Calories, RelativeSource={RelativeSource AncestorType=local:ControlBase}, TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="2" Grid.Column="2" HorizontalAlignment="Right" Padding="0"/>
                <Label Content="{Binding CurrentSummary.Actual.Protein , RelativeSource={RelativeSource AncestorType=local:ControlBase}, TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="3" Grid.Column="2" HorizontalAlignment="Right" Padding="0"/>
                <Label Content="{Binding CurrentSummary.Actual.Carbs,    RelativeSource={RelativeSource AncestorType=local:ControlBase}, TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="4" Grid.Column="2" HorizontalAlignment="Right" Padding="0"/>
                <Label Content="{Binding CurrentSummary.Actual.Fat,      RelativeSource={RelativeSource AncestorType=local:ControlBase}, TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="5" Grid.Column="2" HorizontalAlignment="Right" Padding="0"/>
                
                <!--Column 3 / (fraction)-->
                <Label Content="/" Grid.Row="2" Grid.Column="3" Padding="0"/>
                <Label Content="/" Grid.Row="3" Grid.Column="3" Padding="0"/>
                <Label Content="/" Grid.Row="4" Grid.Column="3" Padding="0"/>
                <Label Content="/" Grid.Row="5" Grid.Column="3" Padding="0"/>
                
                <!--Column 4 Target-->
                <Label Content="{Binding CurrentSummary.Target.Calories, RelativeSource={RelativeSource AncestorType=local:ControlBase}, TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="2" Grid.Column="4" Padding="0"/>
                <Label Content="{Binding CurrentSummary.Target.Protein,  RelativeSource={RelativeSource AncestorType=local:ControlBase}, TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="3" Grid.Column="4" Padding="0"/>
                <Label Content="{Binding CurrentSummary.Target.Carbs,    RelativeSource={RelativeSource AncestorType=local:ControlBase}, TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="4" Grid.Column="4" Padding="0"/>
                <Label Content="{Binding CurrentSummary.Target.Fat,      RelativeSource={RelativeSource AncestorType=local:ControlBase}, TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="5" Grid.Column="4" Padding="0"/>

                <!--Column 5 Percentage-->
                <Label Content="{Binding CalPct, RelativeSource={RelativeSource AncestorType=local:ControlBase}}" Grid.Row="2" Grid.Column="5" Padding="0" HorizontalAlignment="Center"/>
                <Label Content="{Binding ProPct, RelativeSource={RelativeSource AncestorType=local:ControlBase}}" Grid.Row="3" Grid.Column="5" Padding="0" HorizontalAlignment="Center"/>
                <Label Content="{Binding CarPct, RelativeSource={RelativeSource AncestorType=local:ControlBase}}" Grid.Row="4" Grid.Column="5" Padding="0" HorizontalAlignment="Center"/>
                <Label Content="{Binding FatPct, RelativeSource={RelativeSource AncestorType=local:ControlBase}}" Grid.Row="5" Grid.Column="5" Padding="0" HorizontalAlignment="Center"/>

                <!--Column 6 Remaining-->
                <Label Content="{Binding CurrentSummary.Remaining.Calories, RelativeSource={RelativeSource AncestorType=local:ControlBase}, TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="2" Grid.Column="6" Padding="0" HorizontalAlignment="Right"/>
                <Label Content="{Binding CurrentSummary.Remaining.Protein,  RelativeSource={RelativeSource AncestorType=local:ControlBase}, TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="3" Grid.Column="6" Padding="0" HorizontalAlignment="Right"/>
                <Label Content="{Binding CurrentSummary.Remaining.Carbs,    RelativeSource={RelativeSource AncestorType=local:ControlBase}, TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="4" Grid.Column="6" Padding="0" HorizontalAlignment="Right"/>
                <Label Content="{Binding CurrentSummary.Remaining.Fat,      RelativeSource={RelativeSource AncestorType=local:ControlBase}, TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="5" Grid.Column="6" Padding="0" HorizontalAlignment="Right"/>

            </Grid>
            
            <!--Second row (graph, put line graph here)-->
            
        </Grid>
    </Border>
</local:ControlBase>
