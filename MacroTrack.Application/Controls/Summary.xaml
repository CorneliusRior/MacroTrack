<local:ControlBase x:Class="MacroTrack.AppLibrary.Controls.Summary" 
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                   xmlns:local="clr-namespace:MacroTrack.AppLibrary.Controls"
                   xmlns:graphs="clr-namespace:MacroTrack.AppLibrary.Graphs"
                   xmlns:models="clr-namespace:MacroTrack.AppLibrary.Models"
                   xmlns:diag="clr-namespace:System.Diagnostics;assembly=WindowsBase"
                   mc:Ignorable="d"
                   d:DesignHeight="300" d:DesignWidth="700">
    <local:ControlBase.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </local:ControlBase.Resources>
    <Border Background="{DynamicResource PanelBackGroundBrush}">
        <Grid Margin="10" DataContext="{Binding Vm, RelativeSource={RelativeSource AncestorType=local:Summary}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--First row (Summary)-->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="14*"/> <!--Feel free to adjust this-->
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                
                <!--Top/banner-->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.ColumnSpan="7">
                    <Label x:Name="labelGoal"  
                           Content="{Binding CurrentSummary.GoalName, RelativeSource={RelativeSource AncestorType=local:ControlBase}, TargetNullValue='No Goal Selected'}"
                           Style="{DynamicResource Label.Title}"/>
                    <ComboBox x:Name="cbTimeFrame"
                              Visibility="{Binding ShowTimeFrameCB, RelativeSource={RelativeSource AncestorType=local:ControlBase}, Converter={StaticResource BoolToVis}}"
                              Template="{DynamicResource MTComboBoxTemplate}"
                              ItemsSource="{x:Static models:SummaryTimeFrameValues.List}"
                              DisplayMemberPath="Display"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding TimeFrame, RelativeSource={RelativeSource AncestorType=local:ControlBase}, Mode=TwoWay}"
                              Width="125"/>
                </StackPanel>
                
                <!--Ordered in Columns, do each row in the column before moving onto next column-->
                <!--Column 0 MacroLabels:-->
                <Label Content="Calories:" Grid.Row="2" Grid.Column="0" Padding="0"/>
                <Label Content="Protein:" Grid.Row="3" Grid.Column="0" Padding="0"/>
                <Label Content="Carbs:" Grid.Row="4" Grid.Column="0" Padding="0"/>
                <Label Content="Fat:" Grid.Row="5" Grid.Column="0" Padding="0"/>
                
                <!--Column 1 MacroBars:-->
                <graphs:MacroBar Data="{Binding CalSingle}" Margin="1" Grid.Row="2" Grid.Column="1"/>
                <graphs:MacroBar Data="{Binding ProSingle}" Margin="1" Grid.Row="3" Grid.Column="1"/>
                <graphs:MacroBar Data="{Binding CarSingle}" Margin="1" Grid.Row="4" Grid.Column="1"/>
                <graphs:MacroBar Data="{Binding FatSingle}" Margin="1" Grid.Row="5" Grid.Column="1"/>

                <!--Column 2 Actual-->
                <Label Content="{Binding CurrentSummary.Actual.Calories, TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="2" Grid.Column="2" HorizontalAlignment="Right" Padding="0"/>
                <Label Content="{Binding CurrentSummary.Actual.Protein,  TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="3" Grid.Column="2" HorizontalAlignment="Right" Padding="0"/>
                <Label Content="{Binding CurrentSummary.Actual.Carbs,    TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="4" Grid.Column="2" HorizontalAlignment="Right" Padding="0"/>
                <Label Content="{Binding CurrentSummary.Actual.Fat,      TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="5" Grid.Column="2" HorizontalAlignment="Right" Padding="0"/>
                
                <!--Column 3 / (fraction)-->
                <Label Content="/" Grid.Row="2" Grid.Column="3" Padding="0"/>
                <Label Content="/" Grid.Row="3" Grid.Column="3" Padding="0"/>
                <Label Content="/" Grid.Row="4" Grid.Column="3" Padding="0"/>
                <Label Content="/" Grid.Row="5" Grid.Column="3" Padding="0"/>
                
                <!--Column 4 Target-->
                <Label Content="{Binding CurrentSummary.Target.Calories,    TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="2" Grid.Column="4" Padding="0"/>
                <Label Content="{Binding CurrentSummary.Target.Protein,     TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="3" Grid.Column="4" Padding="0"/>
                <Label Content="{Binding CurrentSummary.Target.Carbs,       TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="4" Grid.Column="4" Padding="0"/>
                <Label Content="{Binding CurrentSummary.Target.Fat,         TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="5" Grid.Column="4" Padding="0"/>

                <!--Column 5 Percentage-->
                <Label Content="{Binding CalPct}" Grid.Row="2" Grid.Column="5" Padding="0" HorizontalAlignment="Center"/>
                <Label Content="{Binding ProPct}" Grid.Row="3" Grid.Column="5" Padding="0" HorizontalAlignment="Center"/>
                <Label Content="{Binding CarPct}" Grid.Row="4" Grid.Column="5" Padding="0" HorizontalAlignment="Center"/>
                <Label Content="{Binding FatPct}" Grid.Row="5" Grid.Column="5" Padding="0" HorizontalAlignment="Center"/>

                <!--Column 6 Remaining-->
                <Label Content="{Binding CurrentSummary.Remaining.Calories, TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="2" Grid.Column="6" Padding="0" HorizontalAlignment="Right"/>
                <Label Content="{Binding CurrentSummary.Remaining.Protein,  TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="3" Grid.Column="6" Padding="0" HorizontalAlignment="Right"/>
                <Label Content="{Binding CurrentSummary.Remaining.Carbs,    TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="4" Grid.Column="6" Padding="0" HorizontalAlignment="Right"/>
                <Label Content="{Binding CurrentSummary.Remaining.Fat,      TargetNullValue='-'}" ContentStringFormat="{}{0:N1}" Grid.Row="5" Grid.Column="6" Padding="0" HorizontalAlignment="Right"/>

            </Grid>
            
            <!--Second row (graph, put line graph here)-->
            <Border Padding="0"
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="{DynamicResource ButtonBorderThickness}"
                    Background="{DynamicResource GraphBackGroundBrush}"
                    Grid.Row="1">
                <graphs:MTLineChart x:Name="CalGraph" 
                                    SeriesSet="{Binding GraphSeriesSet}"      
                                    XStart="{Binding GraphStartTime}"
                                    XEnd="{Binding GraphEndTime}"
                                    ClipToChartArea="True"
                                    ShowYAxis="False"
                                    ShowYAxisLabels="False"
                                    Settings="{Binding GraphSettings}"
                                    PlotMargin="8,8,8,16"/>
            </Border>
            
        </Grid>
    </Border>
</local:ControlBase>
