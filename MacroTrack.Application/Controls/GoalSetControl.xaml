<local:ControlBase x:Class="MacroTrack.AppLibrary.Controls.GoalSetControl"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                   xmlns:local="clr-namespace:MacroTrack.AppLibrary.Controls"
                   xmlns:graphs="clr-namespace:MacroTrack.AppLibrary.Graphs"
                   mc:Ignorable="d" 
                   d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="{DynamicResource PanelBackGroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <!--Set inside its own grid in case you want to add anything to the banner-->
                <TextBlock Text="Set Goal" Style="{DynamicResource TextBlock.MidTitle}"/>
            </Grid>

            <Grid Grid.Row="1">
                <!--Main body here.-->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden" Margin="5" Grid.Column="0">
                    <StackPanel Orientation="Vertical">
                        <!--Summary of selected:-->
                        <TextBlock Text="{Binding SelectedGoal.GoalName, FallbackValue='[No Goal Selected]'}" Style="{DynamicResource TextBlock.SmallTitle}"/>
                        <Grid x:Name="donutHost">
                            <Border x:Name="borderDonut" 
                                    BorderBrush="{DynamicResource BorderBrush}" 
                                    BorderThickness="{DynamicResource BorderThickness}" 
                                    MaxWidth="225"
                                    MaxHeight="225"
                                    HorizontalAlignment="Left"
                                    Height="{Binding ActualWidth, ElementName=donutHost}"    
                                    Width="{Binding ActualHeight, ElementName=donutHost}"
                                    Margin="5">
                                <graphs:MTDonut x:Name="donutSelected"
                                    Totals="{Binding SelectedTotals}"
                                    Style="{DynamicResource MTDonutBase}"/>
                            </Border>
                        </Grid>
                        


                            <WrapPanel Orientation="Horizontal">
                            <Label Content="{Binding SelectedGoal.Id, FallbackValue='-'}" Style="{DynamicResource Label.SmallTitle}" ContentStringFormat="#{0}:"/>
                            <Label Content="{Binding SelectedGoal.Calories, FallbackValue='-'}" Style="{DynamicResource Label.SmallTitle}" ContentStringFormat="{}{0:N0} Kcal"/>
                        </WrapPanel>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!--Defined by column:-->
                            <!--Column 0:-->
                            <TextBlock Style="{DynamicResource TextBlock.SingleLine}" Grid.Row="0" Grid.Column="0" Text=""/>
                            <TextBlock Style="{DynamicResource TextBlock.SingleLine}" Grid.Row="1" Grid.Column="0" Text="Calories:"/>
                            <TextBlock Style="{DynamicResource TextBlock.SingleLine}" Grid.Row="2" Grid.Column="0" Text="Protein:"/>
                            <TextBlock Style="{DynamicResource TextBlock.SingleLine}" Grid.Row="3" Grid.Column="0" Text="Carbs:"/>
                            <TextBlock Style="{DynamicResource TextBlock.SingleLine}" Grid.Row="4" Grid.Column="0" Text="Fat:"/>

                            <!--Column 1:-->
                            <Label Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Content="Target:"/>
                            <Label Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" ContentStringFormat="{}{0:N0} Kcal" Content="{Binding SelectedGoal.Calories, FallbackValue='-'}"/>
                            <Label Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" ContentStringFormat="{}{0:0.#}g"    Content="{Binding SelectedGoal.Protein, FallbackValue='-'}"/>
                            <Label Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" ContentStringFormat="{}{0:0.#}g"    Content="{Binding SelectedGoal.Carbs, FallbackValue='-'}"/>
                            <Label Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" ContentStringFormat="{}{0:0.#}g"    Content="{Binding SelectedGoal.Fat, FallbackValue='-'}"/>
                            
                            <!--Column 2:-->
                            <TextBlock Style="{DynamicResource TextBlock.SingleLine}" Grid.Row="0" Grid.Column="2" Text="%:" HorizontalAlignment="Right"/>
                            <TextBlock Style="{DynamicResource TextBlock.SingleLine}" Grid.Row="1" Grid.Column="2" Text="" HorizontalAlignment="Right"/>
                            <TextBlock Style="{DynamicResource TextBlock.SingleLine}" Grid.Row="2" Grid.Column="2" Text="{Binding ProPct}" HorizontalAlignment="Right"/>
                            <TextBlock Style="{DynamicResource TextBlock.SingleLine}" Grid.Row="3" Grid.Column="2" Text="{Binding CarPct}" HorizontalAlignment="Right"/>
                            <TextBlock Style="{DynamicResource TextBlock.SingleLine}" Grid.Row="4" Grid.Column="2" Text="{Binding FatPct}" HorizontalAlignment="Right"/>
                            
                            <!--Column 3:-->
                            <Label Grid.Row="0" Grid.Column="3" Content="Min:" HorizontalAlignment="Right"/>
                            <Label Grid.Row="1" Grid.Column="3" HorizontalAlignment="Right" ContentStringFormat="{}{0:N0} Kcal"  Content="{Binding SelectedGoal.MinCal}"/>
                            <Label Grid.Row="2" Grid.Column="3" HorizontalAlignment="Right" ContentStringFormat="{}{0:0.#}g"     Content="{Binding SelectedGoal.MinPro}"/>
                            <Label Grid.Row="3" Grid.Column="3" HorizontalAlignment="Right" ContentStringFormat="{}{0:0.#}g"     Content="{Binding SelectedGoal.MinCar}"/>
                            <Label Grid.Row="4" Grid.Column="3" HorizontalAlignment="Right" ContentStringFormat="{}{0:0.#}g"     Content="{Binding SelectedGoal.MinFat}"/>

                            <!--Column 3:-->
                            <Label Grid.Row="0" Grid.Column="4" Content="Max:" HorizontalAlignment="Right"/>
                            <Label Grid.Row="1" Grid.Column="4" HorizontalAlignment="Right" ContentStringFormat="{}{0:N0} Kcal" Content="{Binding SelectedGoal.MaxCal}"/>
                            <Label Grid.Row="2" Grid.Column="4" HorizontalAlignment="Right" ContentStringFormat="{}{0:0.#}g"    Content="{Binding SelectedGoal.MaxPro}"/>
                            <Label Grid.Row="3" Grid.Column="4" HorizontalAlignment="Right" ContentStringFormat="{}{0:0.#}g"    Content="{Binding SelectedGoal.MaxCar}"/>
                            <Label Grid.Row="4" Grid.Column="4" HorizontalAlignment="Right" ContentStringFormat="{}{0:0.#}g"    Content="{Binding SelectedGoal.MaxFat}"/>
                        </Grid>
                        <TextBlock Style="{DynamicResource TextBlock.Base}" Text="{Binding SelectedGoal.Notes}"/>
                    </StackPanel>
                </ScrollViewer>

                <GridSplitter Grid.Column="1"/>

                <DataGrid RowHeaderStyle="{DynamicResource MTDataGridRowHeaderStyle}" Template="{DynamicResource MTDataGrid}" ItemsSource="{Binding GoalList}" 
                          SelectedItem="{Binding SelectedGoal}" 
                          IsReadOnly="True"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True"
                          AutoGenerateColumns="False" 
                          Grid.Column="2">
                    
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id, StringFormat={}#{0:N0}}" SortMemberPath="Id"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding GoalName}" SortMemberPath="GoalName" Width="125">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Type"/>
                        <DataGridTextColumn Header="Calories" Binding="{Binding Calories, StringFormat={}{0:N0} kcal}" SortMemberPath="Calories">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Protein" Binding="{Binding Protein, StringFormat={}{0:0.#}g}" SortMemberPath="Protein">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Carbs" Binding="{Binding Carbs, StringFormat={}{0:0.#}g}" SortMemberPath="Carbs">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Fat" Binding="{Binding Fat, StringFormat={}{0:0.#}g}" SortMemberPath="Fat">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" SortMemberPath="Notes" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    <Setter Property="ToolTip" Value="{Binding Notes}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
            
            <StackPanel Style="{DynamicResource StackPanel.Footer}" Grid.Row="2">
                <Button x:Name="buttonDelete" Content="Delete" Style="{DynamicResource Button.Delete}" Command="{Binding DeleteCommand}"/>
                <Button x:Name="buttonCancel" Content="Cancel" Command="{Binding CloseCommand}"/>
                <Button x:Name="buttonSet" Content="Set Goal" Command="{Binding SetCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</local:ControlBase>
