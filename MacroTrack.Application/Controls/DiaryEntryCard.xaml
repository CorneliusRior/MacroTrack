<UserControl x:Name="Root" 
             x:Class="MacroTrack.AppLibrary.Controls.DiaryEntryCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:conv="clr-namespace:MacroTrack.AppLibrary.Converters"
             xmlns:local="clr-namespace:MacroTrack.AppLibrary.Controls"
             mc:Ignorable="d" 
             Margin="5,5,5,0"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <conv:EnumDateTimeConverter x:Key="DateFmt"/>
    </UserControl.Resources>
    <Border Background="{DynamicResource PanelBackGroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="{DynamicResource BorderThickness}"
            Padding="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Label x:Name="PART_labelEntryID"
                       Style="{DynamicResource Label.SmallTitle}"
                       ContentStringFormat="Entry #{0}: "
                       Content="{Binding Entry.Id, ElementName=Root}"
                       Padding="5,5,0,5"
                       Grid.Column="0"/>
                <Label x:Name="PART_labelEntryTime"
                       Style="{DynamicResource Label.SmallTitle}"
                       ContentStringFormat="{Binding TimeFormat, ElementName=Root}"
                       Content="{Binding Entry.Time, ElementName=Root}"
                       Padding="0,5,5,5"
                       Grid.Column="1"/>
            </Grid>


            <TextBlock x:Name="PART_tbxBody"
                       Text="{Binding Entry.Body, ElementName=Root}"
                       Style="{DynamicResource TextBlock.Base}"
                       Grid.Row="1"/>
            <StackPanel Style="{DynamicResource StackPanel.Footer}" Grid.Row="2">
                <Button x:Name="PART_ButtonViewDay"
                        Content="View Day"
                        Command="{Binding DataContext.ViewDayCommand,
                                  RelativeSource={RelativeSource AncestorType=local:DiaryViewControl}}"
                        CommandParameter="{Binding}"/>
                <Button x:Name="PART_ButtonEdit"
                        Content="Edit"
                        Command="{Binding DataContext.EditEntryCommand,
                                  RelativeSource={RelativeSource AncestorType=local:DiaryViewControl}}"
                        CommandParameter="{Binding}"/>
                <Button x:Name="PART_ButtonDelete"
                        Style="{DynamicResource Button.Delete}"
                        Content="Delete"
                        Command="{Binding DataContext.DeleteEntryCommand,
                                  RelativeSource={RelativeSource AncestorType=local:DiaryViewControl}}"
                        CommandParameter="{Binding}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
