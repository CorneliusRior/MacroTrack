<local:ControlBase x:Class="MacroTrack.AppLibrary.Controls.FoodLogInputControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MacroTrack.AppLibrary.Controls"
             xmlns:controls="clr-namespace:MacroTrack.AppLibrary.Controls"
             mc:Ignorable="d" 
             xmlns:conv="clr-namespace:MacroTrack.AppLibrary.Converters"
             d:DesignHeight="300" d:DesignWidth="300">
    <local:ControlBase.Resources>
        <conv:NullableDoubleConverter x:Key="NullDouble"/>
    </local:ControlBase.Resources>
    <Border Background="{DynamicResource PanelBackGroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Label Grid.Row="0"
                   Style="{DynamicResource Label.Title}"
                   Content="Food Entry"/>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <!--Row0-->
                <Label Content="Time:"
                       Grid.Row="0" Grid.Column="0"/>

                <controls:DateTimePicker x:Name="dateTimePicker"
                                         Value="{Binding Time, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                         Format="{Binding DTPFormat}"
                                         Margin="5"
                                         Grid.Row="0" Grid.Column="1"/>

                <Button Content="Current Time"
                        Name="buttonNow"
                        Click="buttonNow_Click"
                        Grid.Row="0" Grid.Column="2"/>

                
                <!--Row1-->
                <Label Content="Item:"
                       Grid.Row="1" Grid.Column="0"/>

                <ComboBox Template="{DynamicResource MTComboBoxTemplate}" 
                          Name="cbItem"
                          DisplayMemberPath="PresetName"
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          ItemsSource="{Binding PresetList}"
                          SelectedItem="{Binding SelectedPreset}"
                          
                          Text="{Binding ItemName,
                                 UpdateSourceTrigger=PropertyChanged,
                                 ValidatesOnNotifyDataErrors=True}"
                          SelectionChanged="cbItem_SelectionChanged"
                          Grid.Row="1" Grid.Column="1"/>

                <controls:SpinBox x:Name="spinMult"
                                  Value="{Binding Mult}"
                                  Step="1"
                                  SmallStep="0.1"
                                  DefaultValue="1"
                                  Margin="5"
                                  Grid.Row="1" Grid.Column="2"/>


                <!--Row2-->
                <Label Content="Filter:"
                       Grid.Row="2" Grid.Column="0"/>

                <ComboBox Template="{DynamicResource MTComboBoxTemplate}"
                          Name="cbFilter"
                          ItemsSource="{Binding CatList}"
                          Text="{Binding CategoryText, 
                                 UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          SelectionChanged="cbFilter_SelectionChanged"
                          Grid.Row="2" Grid.Column="1"/>

                <Button Content="New Preset"
                        Name="buttonNewPreset"
                        Click="buttonNewPreset_Click"
                        HorizontalAlignment="Stretch"
                        Grid.Row="2" Grid.Column="2"/>
                
                <!--Row3-->
                <WrapPanel Orientation="Horizontal"
                           Grid.Row="3" Grid.ColumnSpan="3">

                    <Grid> <!--Cal input-->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Cal:"
                               Grid.Column="0"/>
                        <TextBox x:Name="tbCal"
                                 Text="{Binding Cal, 
                                        Converter={StaticResource NullDouble},
                                        UpdateSourceTrigger=PropertyChanged,
                                        ValidatesOnNotifyDataErrors=True}"                                 
                                 Style="{DynamicResource TextBox.Numeric}"
                                 Grid.Column="1"/>
                    </Grid>

                    <Grid>
                        <!--Pro input-->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Pro:"
                               Grid.Column="0"/>
                        <TextBox x:Name="tbPro"
                                 Text="{Binding Pro, 
                                        Converter={StaticResource NullDouble},
                                        UpdateSourceTrigger=PropertyChanged,
                                        ValidatesOnNotifyDataErrors=True}"  
                                 Style="{DynamicResource TextBox.Numeric}"
                                 Grid.Column="1"/>
                    </Grid>

                    <Grid>
                        <!--Car input-->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Car:"
                               Grid.Column="0"/>
                        <TextBox x:Name="tbCar"
                                 Text="{Binding Car, 
                                        Converter={StaticResource NullDouble},
                                        UpdateSourceTrigger=PropertyChanged,
                                        ValidatesOnNotifyDataErrors=True}"  
                                 Style="{DynamicResource TextBox.Numeric}"
                                 Grid.Column="1"/>
                    </Grid>

                    <Grid>
                        <!--Pro input-->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Fat:"
                               Grid.Column="0"/>
                        <TextBox x:Name="tbFat"
                                 Text="{Binding Fat, 
                                         Converter={StaticResource NullDouble},
                                         UpdateSourceTrigger=PropertyChanged,
                                         ValidatesOnNotifyDataErrors=True}"  
                                 Style="{DynamicResource TextBox.Numeric}"
                                 Grid.Column="1"/>
                    </Grid>

                </WrapPanel>
                
                <!--Row4-->
                <Label Content="Notes:"
                       Grid.Row="4" Grid.Column="0"/>
                
                <!--Row5-->
                <TextBox x:Name="Notes"
                         Text="{Binding Notes}"
                         Style="{DynamicResource TextBox.MultiLine}"
                         VerticalAlignment="Stretch"
                         Grid.Row="5" Grid.ColumnSpan="3"/>



            </Grid>
            
            <StackPanel Grid.Row="2"
                        Style="{DynamicResource StackPanel.Footer}">
                <Button Content="Clear"
                        Name="ButtonClear"
                        Click="ButtonClear_Click"/>
                <Button Content="Add"
                        Name="ButtonAdd"
                        Click="ButtonAdd_Click"
                        Command="{Binding RefreshSummaryCommand, RelativeSource={RelativeSource AncestorType=local:ControlBase}}"/>
                
            </StackPanel>
        </Grid>                
    </Border>
</local:ControlBase>
