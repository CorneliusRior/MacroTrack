<local:ControlBase x:Class="MacroTrack.AppLibrary.Controls.AddLogEntryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MacroTrack.AppLibrary.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="{DynamicResource PanelBackGroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Label Grid.Row="0"
                   Content="Add Log Entry"
                   Style="{StaticResource Label.Title}"/>

            <Grid Grid.Row="1"
                  Margin="10,0,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="{Binding LastAdded}"
                           Style="{DynamicResource TextBlock.Base}"
                           Margin="5"/>
            
                <TextBox Grid.Row="1"
                         x:Name="tbLog"
                         Style="{DynamicResource TextBox.MultiLine}"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         TextWrapping="Wrap"/>
            
                <Button Grid.Row="2"
                        x:Name="buttonAdd"
                        Content="Add"
                        HorizontalAlignment="Right"
                        Click="buttonAdd_Click"/>

            </Grid>


        </Grid>
    </Border>
</local:ControlBase>
