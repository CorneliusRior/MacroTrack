<UserControl x:Class="MacroTrack.AppLibrary.Controls.FoodEntryCard" x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:set="clr-namespace:MacroTrack.Core.Settings;assembly=MacroTrack.Core"
             xmlns:conv="clr-namespace:MacroTrack.AppLibrary.Converters"
             xmlns:local="clr-namespace:MacroTrack.AppLibrary.Controls"
             Margin="0,0,5,5"
             
             mc:Ignorable="d" 
             d:DesignWidth="300"
             Height="auto">
    <UserControl.Resources>
        <conv:EnumDateTimeConverter x:Key="DateFmt"/>
    </UserControl.Resources>
    <Border Background="{DynamicResource PanelBackGroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="{DynamicResource BorderThickness}" Padding="7">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Label Name="PART_LabelTitle"
                       Content="{Binding Entry.ItemName, ElementName=Root}"
                       Padding="2"
                       Style="{DynamicResource Label.Title}"
                       Grid.Row="0"/>
                <StackPanel Orientation="Horizontal"
                           Grid.Row="1">
                    <Label x:Name="PART_LabelCal" 
                           Padding="2"  
                           ContentStringFormat="Cal: {0:N1}"
                           Content="{Binding Entry.Calories, ElementName=Root}"/>
                    <Label x:Name="PART_LabelPro" 
                           Padding="2"  
                           ContentStringFormat="Pro: {0:N1}"
                           Content="{Binding Entry.Protein, ElementName=Root}"/>
                    <Label x:Name="PART_LabelCae" 
                           Padding="2"  
                           ContentStringFormat="Car: {0:N1}"
                           Content="{Binding Entry.Carbs, ElementName=Root}"/>
                    <Label x:Name="PART_LabelFat" 
                           Padding="2"  
                           ContentStringFormat="Fat: {0:N1}"
                           Content="{Binding Entry.Fat, ElementName=Root}"/>
                </StackPanel>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Label x:Name="PART_LabelTime"
                           ContentStringFormat="{Binding TimeFormat, ElementName=Root}"
                           Content="{Binding Entry.Time, ElementName=Root}"
                           Padding="2"
                           Grid.Column="0"/>
                    <Label x:Name="PART_LabelMult"
                           ContentStringFormat="(x{0:N1})"
                           Content="{Binding Entry.Amount, ElementName=Root}"
                           Padding="2"
                           Grid.Column="1"/>
                </Grid>
                <Label x:Name="PART_LabelNotes"
                       Content="{Binding Entry.Notes, ElementName=Root, TargetNullValue=''}"                       
                       FontStyle="Italic"
                       Padding="2"
                       Grid.Row="3"/>

            </Grid>
            
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Button x:Name="buttonEdit"
                        Content="Edit"
                        Command="{Binding DataContext.EditEntryCommand, 
                                  RelativeSource={RelativeSource AncestorType=local:HistoryControl}}"
                        CommandParameter="{Binding}"
                        VerticalAlignment="Bottom"
                        Grid.Row="0"/>
                <Button x:Name="buttonDelete"
                        Content="Delete"
                        Command="{Binding DataContext.DeleteEntryCommand, 
                                  RelativeSource={RelativeSource AncestorType=local:HistoryControl}}"
                        CommandParameter="{Binding}"
                        VerticalAlignment="Top"
                        Grid.Row="1"/>
            </Grid>

        </Grid>
        
    </Border>
    
</UserControl>
