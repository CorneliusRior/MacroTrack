<UserControl x:Class="MacroTrack.AppLibrary.Graphs.MTDonut"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             MinHeight="100" MinWidth="100"
             d:DesignHeight="300" d:DesignWidth="300"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <Grid>
        <!--Drawing Surface-->
        <Canvas x:Name="PART_Canvas" Background="{Binding BackgroundBrush, ElementName=Root}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        <!--Centre text-->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
            <TextBlock x:Name="PART_CenterText"
               Text="Calories"
               FontSize="{Binding LabelFontSize, ElementName=Root}"
               Foreground="{Binding LabelBrush, ElementName=Root}"
               HorizontalAlignment="Center"/>
            <TextBlock x:Name="PART_CenterValue"
               Text="2000"
               FontSize="{Binding LabelFontSize, ElementName=Root}"
               Foreground="{Binding LabelBrush, ElementName=Root}"
               HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
