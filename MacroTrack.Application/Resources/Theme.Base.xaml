<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:graphs="clr-namespace:MacroTrack.AppLibrary.Graphs"
                    xmlns:System="clr-namespace:System;assembly=mscorlib">
    
    <!--General Brushes-->
    <SolidColorBrush x:Key="AppBackGroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="AppForeGroundBrush" Color="#FF000000"/>
    <SolidColorBrush x:Key="PanelBackGroundBrush" Color="#FFF6F6F6"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#FF000000"/>
    <SolidColorBrush x:Key="CaretBrush" Color="#FF000000"/>


    <SolidColorBrush x:Key="HighLightBrush" Color="#FF888888"/>
    <SolidColorBrush x:Key="HighLightTextBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ControlTextBrushKey" Color="#FFFFFFFF"/>

    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF888888"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FFFFFFFF"/>

    <!--Control Brushes-->
    <SolidColorBrush x:Key="ButtonBackGroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FFF9F9F9"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#FFEEEEEE"/>

    <SolidColorBrush x:Key="TextBoxBackgroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="TextBoxHoverBrush" Color="#FFFFFFFF"/>

    <SolidColorBrush x:Key="HoverBorderBrush" Color="#FF888888"/>
    <SolidColorBrush x:Key="SelectedBorderBrush" Color="#FF000000"/>


    <!--Graphing Parameters-->
    <SolidColorBrush x:Key="GraphBackGroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="GraphColorPro" Color="Red"/>
    <SolidColorBrush x:Key="GraphColorCar" Color="Blue"/>
    <SolidColorBrush x:Key="GraphColorFat" Color="Yellow"/>
    <System:Boolean x:Key="MTDonutHatch">true</System:Boolean>
    <SolidColorBrush x:Key="MacroBrushGood" Color="Green"/>
    <SolidColorBrush x:Key="MacroBrushNeutral" Color="Yellow"/>
    <SolidColorBrush x:Key="MacroBrushBad" Color="Red"/>
    <SolidColorBrush x:Key="GraphGridBrush" Color="Gray"/>
    
    <!--Graph Series Parameters-->
    <SolidColorBrush x:Key="LineSeriesBrush1" Color="#FF000000"/>
    <SolidColorBrush x:Key="LineSeriesBrush2" Color="#FFFF0000"/>
    <SolidColorBrush x:Key="LineSeriesBrush3" Color="#FF0000FF"/>

    <SolidColorBrush x:Key="DayBinarySeriesBrush1" Color="#FF00BB00"/>

    <!--Other formatting-->
    <Thickness x:Key="BorderThickness">2</Thickness>
    <Thickness x:Key="ButtonBorderThickness">1</Thickness>
    <Thickness x:Key="SelectedBorderThickness">1.2</Thickness>
    
    <!--Font-->
    <FontFamily x:Key="UIFont">Segoe UI</FontFamily>
    <System:Double x:Key="UISmallSize">9</System:Double>
    <System:Double x:Key="UINormalSize">12</System:Double>
    <System:Double x:Key="UISmallTitleSize">14</System:Double>
    <System:Double x:Key="UITitleSize">16</System:Double>
    <System:Double x:Key="UIMainTitleSize">28</System:Double>

    <FontFamily x:Key="ReplFont">Consolas</FontFamily>
    <System:Double x:Key="ReplSize">14</System:Double>
    
</ResourceDictionary>