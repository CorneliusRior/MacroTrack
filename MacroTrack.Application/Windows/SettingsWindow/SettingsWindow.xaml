<MTWin:WindowBase x:Class="MacroTrack.AppLibrary.Windows.SettingsWindow.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:MacroTrack.AppLibrary.Converters"
        xmlns:local="clr-namespace:MacroTrack.AppLibrary.Windows.SettingsWindow"
        xmlns:cat="clr-namespace:MacroTrack.AppLibrary.Windows.SettingsWindow.Categories"
                  xmlns:MTWin="clr-namespace:MacroTrack.AppLibrary.Windows"
        mc:Ignorable="d"
        Title="SettingsWindow" Height="700" Width="600">
    <MTWin:WindowBase.Resources>
        <conv:EnumRadioConverter x:Key="EnumRadioConverter"/>
        <DataTemplate DataType="{x:Type cat:GeneralVM}">
            <cat:General/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type cat:LoggingVM}">
            <cat:Logging/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type cat:FormattingVM}">
            <cat:Formatting/>
        </DataTemplate>
    </MTWin:WindowBase.Resources>
    
    <Border Background="{DynamicResource PanelBackGroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Content="Settings" Style="{DynamicResource Label.Title}" Grid.Row="0" Grid.Column="0"/>
            <StackPanel Style="{DynamicResource StackPanel.Footer}" Grid.Row="0" Grid.Column="1">
                <Button Content="Revert" Name="ButtonRevert" Click="ButtonRevert_Click"/>
                <Button Content="Default" Name="ButtonDefault" Click="ButtonDefault_Click"/>
            </StackPanel>

            <ListBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Margin="25"
                     Grid.Row="1" Grid.Column="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Title}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ContentControl Content="{Binding SelectedCategory}"
                            Grid.Row="1" Grid.Column="1"/>

            <StackPanel Style="{DynamicResource StackPanel.Footer}" 
                        Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                <Button Content="Cancel" Name="ButtonCancel" Click="ButtonCancel_Click"/>
                <Button Content="Apply" Name="ButtonApply" Click="ButtonApply_Click"/>
            </StackPanel>

        </Grid>
    </Border>
</MTWin:WindowBase>
