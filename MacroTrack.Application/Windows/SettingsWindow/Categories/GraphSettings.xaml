<UserControl x:Class="MacroTrack.AppLibrary.Windows.SettingsWindow.Categories.GraphSettings"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:c="clr-namespace:MacroTrack.AppLibrary.Controls"
             xmlns:local="clr-namespace:MacroTrack.AppLibrary.Windows.SettingsWindow.Categories"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="450">
    <Border Background="{DynamicResource PanelBackGroundBrush}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical"
                        Margin="10">
                <Expander Header="Line Graph" IsExpanded="True">
                    <c:LabelledNumericInput LabelText="Trend line thickness"
                        Value="{Binding SettingsEditable.GraphSettings.LineTrendLineThickness, Mode=TwoWay}"
                        Min="0"/>
                </Expander>

                <Expander Header="Donut Graph" IsExpanded="True">

                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
