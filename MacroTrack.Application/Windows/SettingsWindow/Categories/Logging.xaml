<UserControl x:Class="MacroTrack.AppLibrary.Windows.SettingsWindow.Categories.Logging"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:c="clr-namespace:MacroTrack.AppLibrary.Controls"
             xmlns:log="clr-namespace:MacroTrack.Core.Logging;assembly=MacroTrack.Core"
             xmlns:conv="clr-namespace:MacroTrack.AppLibrary.Converters"
             xmlns:local="clr-namespace:MacroTrack.AppLibrary.Windows.SettingsWindow.Categories"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="450">
    <Control.Resources>
        <conv:EnumRadioConverter x:Key="EnumRadioConverter"/>
    </Control.Resources>
    <Border Background="{DynamicResource PanelBackGroundBrush}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical"
                        Margin="10">
                <Expander Header="General" IsExpanded="True">
                    <StackPanel>
                        <c:LabelledNumericInput LabelText="Log Retain amount"
                                                Value="{Binding SettingsEditable.LogRetainAmount,Mode=TwoWay}"
                                                Min="1"/>
                        <CheckBox Content="Log Initiation Messages"
                                  IsChecked="{Binding SettingsEditable.LogInitMessages, Mode=TwoWay}"/>
                    </StackPanel>
                </Expander>
                <Expander Header="Logging Threshold" IsExpanded="True">
                    <StackPanel>
                        <Label Content="UI Logging Threshold:"/>
                        <RadioButton Content="Debug" GroupName="LogUILevel"
                                     IsChecked="{Binding SettingsEditable.LogUILevel, 
                                                Converter={StaticResource EnumRadioConverter},
                                                ConverterParameter={x:Static log:LogLevel.Debug},
                                                Mode=TwoWay}"/>
                        <RadioButton Content="Info" GroupName="LogUILevel"
                                     IsChecked="{Binding SettingsEditable.LogUILevel, 
                                                Converter={StaticResource EnumRadioConverter},
                                                ConverterParameter={x:Static log:LogLevel.Info},
                                                Mode=TwoWay}"/>
                        <RadioButton Content="Warning" GroupName="LogUILevel"
                                     IsChecked="{Binding SettingsEditable.LogUILevel, 
                                                Converter={StaticResource EnumRadioConverter},
                                                ConverterParameter={x:Static log:LogLevel.Warning},
                                                Mode=TwoWay}"/>
                        <RadioButton Content="Error" GroupName="LogUILevel"
                                     IsChecked="{Binding SettingsEditable.LogUILevel,
                                                Converter={StaticResource EnumRadioConverter},
                                                ConverterParameter={x:Static log:LogLevel.Error},
                                                Mode=TwoWay}"/>

                        <Label Content="File Logging Threshold:"/>
                        <RadioButton Content="Debug" GroupName="LogFileLevel"
                                     IsChecked="{Binding SettingsEditable.LogFileLevel, 
                                                Converter={StaticResource EnumRadioConverter},
                                                ConverterParameter={x:Static log:LogLevel.Debug},
                                                Mode=TwoWay}"/>
                            <RadioButton Content="Info" GroupName="LogFileLevel"
                                         IsChecked="{Binding SettingsEditable.LogFileLevel, 
                                                    Converter={StaticResource EnumRadioConverter},
                                                    ConverterParameter={x:Static log:LogLevel.Info},
                                                    Mode=TwoWay}"/>
                            <RadioButton Content="Warning" GroupName="LogFileLevel"
                                         IsChecked="{Binding SettingsEditable.LogFileLevel, 
                                                    Converter={StaticResource EnumRadioConverter},
                                                    ConverterParameter={x:Static log:LogLevel.Warning},
                                                    Mode=TwoWay}"/>
                            <RadioButton Content="Error" GroupName="LogFileLevel"
                                         IsChecked="{Binding SettingsEditable.LogFileLevel,
                                                    Converter={StaticResource EnumRadioConverter},
                                                    ConverterParameter={x:Static log:LogLevel.Error},
                                                    Mode=TwoWay}"/>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
