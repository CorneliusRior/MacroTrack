<Window x:Class="MacroTrack.Dashboard.MainWindow" x:Name="Root"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MacroTrack.Dashboard"
        xmlns:views="clr-namespace:MacroTrack.AppLibrary.Controls;assembly=MacroTrack.AppLibrary"
        xmlns:graphs="clr-namespace:MacroTrack.AppLibrary.Graphs;assembly=MacroTrack.AppLibrary"
        xmlns:controls="clr-namespace:MacroTrack.AppLibrary.Controls;assembly=MacroTrack.AppLibrary"
        mc:Ignorable="d"
        Title="MacroTrack" Height="1080" Width="1920"
        
        Background="{DynamicResource AppBackGroundBrush}"
        Foreground="{DynamicResource AppForeGroundBrush}"
        >

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="14*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!--Main UI Space-->
        <Grid Grid.Column="0" Margin="5,5,0,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--Banner-->
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="{DynamicResource BorderThickness}"
                    Background="{DynamicResource PanelBackGroundBrush}"
                    Margin="0,0,0,5"
                    Padding="20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0"
                           Style="{StaticResource Label.MainTitle}"
                           Content="MacroTrack"
                           Margin="0"/>

                    <StackPanel Grid.Column="1" 
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Height="50">

                        <Button Content="Yesterday"
                                Name="ButtonBannerYesterday"
                                Click="ButtonBannerYesterday_Click"/>
                        <Button Content="Previous Periods" 
                                Name="ButtonBannerPreviousPeriods"
                                Click="ButtonBannerPreviousPeriods_Click"/>
                        <Button Content="Set Goal"
                                Name="BannerButtonSetGoal"
                                Click="BannerButtonSetGoal_Click"/>
                        <Button Content="New Goal"
                                Name="BannerButtonNewGoal"
                                Click="BannerButtonNewGoal_Click"/>
                        <Button Content="Settings"
                                Name="ButtonBannerSettings"
                                Click="ButtonBannerSettings_Click"/>
                        <Button Content="Open Log"
                                Name="ButtonBannerOpenLog"
                                Click="ButtonBannerOpenLog_Click"/>
                        <Button Content="Open Log Directory"
                                Name="ButtonBannerLogDirectory"
                                Click="ButtonBannerLogDirectory_Click"/>

                    </StackPanel>

                    <Label Grid.Column="2"
                           Style="{StaticResource Label.Title}"
                           Content="{Binding DataContext.ClockString, ElementName=Root}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>

            </Border>




            <!--First Row-->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="{DynamicResource BorderThickness}"
                    Background="{DynamicResource PanelBackGroundBrush}">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <graphs:MTDonut x:Name="DonutPresent"
                                        Summary="{Binding CurrentSummary}"
                                        TotalType="Actual"
                                        Grid.Column="0"/>
                        <graphs:MTDonut x:Name="DonutGoal"
                                        Summary="{Binding CurrentSummary}"
                                        TotalType="Target"
                                        Grid.Column="1"/>

                    </Grid>

                </Border>

                <GridSplitter Grid.Column="1"/>

                <Border Grid.Column="2"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{DynamicResource BorderThickness}"
                        Background="{DynamicResource PanelBackGroundBrush}">
                    <controls:Summary x:Name="Summary" 
                                      CurrentSummary="{Binding CurrentSummary}"
                                      TimeFrame="{Binding SummaryTimeFrame, Mode=TwoWay}"/>

                </Border>

                <GridSplitter Grid.Column="3"/>

                <Border Grid.Column="4"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{DynamicResource BorderThickness}"
                        Background="{DynamicResource PanelBackGroundBrush}"/>

            </Grid>

            <GridSplitter Grid.Row="2"/>

            <!--Second Row-->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{DynamicResource BorderThickness}"
                        Background="{DynamicResource PanelBackGroundBrush}">

                    <views:FoodEntryControl x:Name="FoodEntry"
                                            RequestRefreshCommand="{Binding DataContext.RefreshSummaryCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>

                </Border>

                <GridSplitter Grid.Column="1"/>

                <Border Grid.Column="2"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{DynamicResource BorderThickness}"
                        Background="{DynamicResource PanelBackGroundBrush}">

                    <views:WeightEntryControl x:Name="WeightEntry"/>

                </Border>

                <GridSplitter Grid.Column="3"/>

                <Border Grid.Column="4"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{DynamicResource BorderThickness}"
                        Background="{DynamicResource PanelBackGroundBrush}">

                    <views:DiaryEntryControl x:Name="DiaryEntry"/>

                </Border>

            </Grid>

            <GridSplitter Grid.Row="4"/>

            <!--REPL-->
            <Border Grid.Row="5"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="{DynamicResource BorderThickness}"
                    Background="{DynamicResource PanelBackGroundBrush}">

                <views:ReplControl x:Name="Repl"/>

            </Border>
        </Grid>

        <!--Main UI/History splitter-->
        <GridSplitter Grid.Column="1"/>

        <!--History-->
        
        <Grid Grid.Column="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="{DynamicResource BorderThickness}"
                    Background="{DynamicResource PanelBackGroundBrush}"
                    Margin="0,5,5,0"
                    Padding="20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Recent Entries (3 days)"
                           Style="{DynamicResource Label.Title}"
                           Grid.Column="0"/>
                    <Button Content="Refresh"
                            Command="{Binding DataContext.RefreshSummaryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Grid.Column="1"/>

                </Grid>
            </Border>
            
            <Border Grid.Row="1"
                    Padding="0"
                    Margin="0,5,5,5">
                <controls:HistoryControl x:Name="History"/>
            </Border>
        </Grid>
            
        

    </Grid>
</Window>
