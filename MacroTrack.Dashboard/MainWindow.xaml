<Window x:Class="MacroTrack.Dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MacroTrack.Dashboard"
        xmlns:views="clr-namespace:MacroTrack.AppLibrary.Controls;assembly=MacroTrack.AppLibrary"
        xmlns:controls="clr-namespace:MacroTrack.AppLibrary.Controls;assembly=MacroTrack.AppLibrary"
        mc:Ignorable="d"
        Title="MacroTrack" Height="1080" Width="1920"
        
        Background="{DynamicResource AppBackGroundBrush}"
        Foreground="{DynamicResource AppForeGroundBrush}"
        >

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--Main UI Space-->
        <Grid Grid.Column="0" Margin="5,5,0,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--Banner-->
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="{DynamicResource BorderThickness}"
                    Background="{DynamicResource PanelBackGroundBrush}"
                    Margin="0,0,0,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0"
                           Style="{StaticResource Label.MainTitle}"
                           Content="MacroTrack"
                           Padding="20,0" Margin="0"/>

                    <StackPanel Grid.Column="1" 
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Height="50">

                        <Button Content="Yesterday"
                                Name="ButtonBannerYesterday"
                                Click="ButtonBannerYesterday_Click"/>
                        <Button Content="Previous Periods" 
                                Name="ButtonBannerPreviousPeriods"
                                Click="ButtonBannerPreviousPeriods_Click"/>
                        <Button Content="Set Goal"
                                Name="BannerButtonSetGoal"
                                Click="BannerButtonSetGoal_Click"/>
                        <Button Content="New Goal"
                                Name="BannerButtonNewGoal"
                                Click="BannerButtonNewGoal_Click"/>
                        <Button Content="Settings"
                                Name="ButtonBannerSettings"
                                Click="ButtonBannerSettings_Click"/>
                        <Button Content="Light/Dark Mode"
                                Name="ButtonBannerLightDark"
                                Click="ButtonBannerLightDark_Click"/>

                    </StackPanel>

                    <Label Grid.Column="2"
                           Style="{StaticResource Label.Title}"
                           Content="19:33 30/01/2026"
                           VerticalAlignment="Center"
                           Padding="20"/>
                </Grid>

            </Border>




            <!--First Row-->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="{DynamicResource BorderThickness}"
                    Background="{DynamicResource PanelBackGroundBrush}"/>

                <GridSplitter Grid.Column="1"/>

                <Border Grid.Column="2"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{DynamicResource BorderThickness}"
                        Background="{DynamicResource PanelBackGroundBrush}"/>

                <GridSplitter Grid.Column="3"/>

                <Border Grid.Column="4"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{DynamicResource BorderThickness}"
                        Background="{DynamicResource PanelBackGroundBrush}"/>

            </Grid>

            <GridSplitter Grid.Row="2"/>

            <!--Second Row-->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{DynamicResource BorderThickness}"
                        Background="{DynamicResource PanelBackGroundBrush}">

                    <views:FoodEntryControl x:Name="FoodEntry"/>

                </Border>

                <GridSplitter Grid.Column="1"/>

                <Border Grid.Column="2"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{DynamicResource BorderThickness}"
                        Background="{DynamicResource PanelBackGroundBrush}">

                    <views:AddLogEntryControl x:Name="AddLogEntry"/>

                </Border>

                <GridSplitter Grid.Column="3"/>

                <Border Grid.Column="4"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{DynamicResource BorderThickness}"
                        Background="{DynamicResource PanelBackGroundBrush}">

                    <views:DiaryEntryControl x:Name="DiaryEntry"/>

                </Border>

            </Grid>

            <GridSplitter Grid.Row="4"/>

            <!--REPL-->
            <Border Grid.Row="5"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="{DynamicResource BorderThickness}"
                    Background="{DynamicResource PanelBackGroundBrush}">

                <views:ReplControl x:Name="Repl"/>

            </Border>
        </Grid>

        <!--Main UI/History splitter-->
        <GridSplitter Grid.Column="1"/>

        <!--History-->
        <Border Grid.Column="4"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{DynamicResource BorderThickness}"
                Background="{DynamicResource PanelBackGroundBrush}"
                Margin="0,5,5,5"/>

    </Grid>
</Window>
