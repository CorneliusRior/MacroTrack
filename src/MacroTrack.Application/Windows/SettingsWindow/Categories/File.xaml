<UserControl x:Class="MacroTrack.AppLibrary.Windows.SettingsWindow.Categories.File"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MacroTrack.AppLibrary.Windows.SettingsWindow.Categories"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="450">
    <Border Background="{DynamicResource PanelBackGroundBrush}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical" Margin="10">
                <Expander Header="Data" IsExpanded="True">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                        <Button x:Name="buttonExportData"
                                Content="Export to Excel"
                                Command="{Binding ExportDataCommand}"
                                HorizontalAlignment="Left"/>
                        <Button x:Name="buttonOpenDataFile"
                                Content="Open Data File"
                                Command="{Binding OpenDataFileCommand}"
                                HorizontalAlignment="Left"/>
                    </StackPanel> 
                </Expander>
                <Expander Header="Logging" IsExpanded="True">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                        <Button x:Name="buttonViewLog"
                                Content="Open Log File"
                                Command="{Binding ViewLogCommand}"
                                HorizontalAlignment="Left"/>
                        <Button x:Name="buttonViewDirFile"
                                Content="Open Log Directory"
                                Command="{Binding ViewLogDirCommand}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
