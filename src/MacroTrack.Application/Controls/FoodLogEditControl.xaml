<local:ControlBase x:Class="MacroTrack.AppLibrary.Controls.FoodLogEditControl"                
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                   xmlns:local="clr-namespace:MacroTrack.AppLibrary.Controls"
                   mc:Ignorable="d" 
                   d:DesignHeight="350" d:DesignWidth="400">
    <Border Background="{DynamicResource PanelBackGroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Edit Food Log Entry" Style="{DynamicResource TextBlock.MidTitle}" Grid.Row="0"/>

            <!--Main grid:-->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <!--Row 0-->
                <Label Content="Time:" Target="{Binding ElementName=dtpTime}" Grid.Row="0" Grid.Column="0"/>
                <local:DateTimePicker x:Name="dtpTime"
                                      Value="{Binding Time}"
                                      Margin="5"
                                      Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"/>
                <Button Name="buttonNow"
                        Content="Current Time"
                        Grid.Row="0" Grid.Column="3"/>
                
                <!--Row 1-->
                <Label Content="Item Name:" Target="{Binding ElementName=tbItemName}" Grid.Row="1" Grid.Column="0"/>
                <TextBox x:Name="tbItemName" Text="{Binding ItemName}" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"/>
                
                <!--Row 2-->
                <Label Content="Amount:" Target="{Binding ElementName=spinMult}" Grid.Row="2" Grid.Column="0"/>
                <local:SpinBox x:Name="spinMult" 
                               Value="{Binding Mult}"
                               Width="75"
                               Step="1"
                               SmallStep="0.1"
                               Margin="5"
                               Grid.Row="2" Grid.Column="1"/>
                <!--You could add a textbox here which tries to calculate what it is if item name matches name of a preset-->

                <!--Row 3 Macros-->
                <WrapPanel Orientation="Horizontal" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Cal:" Target="{Binding ElementName=tbCal}" Grid.Column="0"/>
                        <TextBox x:Name="tbCal"
                                 Text="{Binding Cal}"
                                 Style="{DynamicResource TextBox.Numeric}"
                                 Grid.Column="1"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Pro:" Target="{Binding ElementName=tbPro}" Grid.Column="0"/>
                        <TextBox x:Name="tbPro"
                                 Text="{Binding Pro}"
                                 Style="{DynamicResource TextBox.Numeric}"
                                 Grid.Column="1"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Car:" Target="{Binding ElementName=tbCar}" Grid.Column="0"/>
                        <TextBox x:Name="tbCar"
                                 Text="{Binding Car}"
                                 Style="{DynamicResource TextBox.Numeric}"
                                 Grid.Column="1"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Fat:" Target="{Binding ElementName=tbFat}" Grid.Column="0"/>
                        <TextBox x:Name="tbFat"
                                 Text="{Binding Fat}"
                                 Style="{DynamicResource TextBox.Numeric}"
                                 Grid.Column="1"/>
                    </Grid>
                </WrapPanel>
                
                <!--Notes:-->
                <Label Content="Notes:" Grid.Row="4" Grid.Column="0"/>
                <TextBox x:Name="tbNotes" Text="{Binding Notes}" Style="{DynamicResource TextBox.MultiLine}" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="4"/>
            </Grid>

            <StackPanel Style="{DynamicResource StackPanel.Footer}" Grid.Row="2">
                <Button x:Name="buttonDelete"
                        Content="Delete"
                        Style="{DynamicResource Button.Delete}"
                        Click="buttonDelete_Click"/>
                <Button x:Name="buttonCancel"
                        Content="Cancel"
                        Click="buttonCancel_Click"/>
                <Button x:Name="buttonEdit"
                        Content="Edit"
                        Click="buttonEdit_Click"/>
            </StackPanel>

        </Grid>
    </Border>
</local:ControlBase>
