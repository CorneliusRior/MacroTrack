<UserControl x:Class="MacroTrack.AppLibrary.Controls.WeightEntryCard"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:conv="clr-namespace:MacroTrack.AppLibrary.Converters"
             xmlns:local="clr-namespace:MacroTrack.AppLibrary.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="30" d:DesignWidth="300">
    <UserControl.Resources>
        <conv:SelectionChangedConverter x:Key="SelectionConv"/>
    </UserControl.Resources>
    <Border Background="{DynamicResource PanelBackGroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="{DynamicResource ButtonBorderThickness}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" MinWidth="40"/>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="PART_tbxID"
                       Text="{Binding Entry.Id, StringFormat='#\{0\}', ElementName=Root}"
                       Style="{DynamicResource TextBlock.SingleLine}"                       
                       HorizontalAlignment="Center"                       
                       Grid.Column="0"/>
            <Label x:Name="PART_labelEntryTime"                   
                   ContentStringFormat="{Binding TimeFormat, ElementName=Root}"
                   Content="{Binding Entry.Time, ElementName=Root}"
                   Padding="0,5,5,5"
                   Grid.Column="1"/>
            <TextBlock x:Name="PART_tbxWeight"
                       Text="{Binding Entry.Weight, ElementName=Root}"
                       TextAlignment="Right"                       
                       Style="{DynamicResource TextBlock.SingleLine}"
                       FontWeight="Bold"
                       Grid.Column="2"/>
            <TextBlock x:Name="PART_tbxUnit"
                       Text="{Binding UnitLabel, ElementName=Root}"
                       TextAlignment="Left"
                       Margin="0"
                       Style="{DynamicResource TextBlock.SingleLine}"
                       FontWeight="Bold"
                       Grid.Column="3"/>
            <CheckBox x:Name="PART_cbxSelected"
                      HorizontalAlignment="Right"
                      Grid.Column="4">
                <CheckBox.Command>
                    <Binding Path="DataContext.SelectionChangedCommand"
                             RelativeSource="{RelativeSource AncestorType={x:Type local:WeightViewControl}}"/>
                </CheckBox.Command>
                <CheckBox.CommandParameter>
                    <MultiBinding Converter="{StaticResource SelectionConv}">
                        <Binding />
                        <Binding RelativeSource="{RelativeSource Self}" Path="IsChecked"/>
                    </MultiBinding>
                </CheckBox.CommandParameter>
            </CheckBox>
        </Grid>
    </Border>
</UserControl>
