<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Theme.Base.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!--Overrides-->
    
    <!--General Brushes-->
    <SolidColorBrush x:Key="AppBackGroundBrush" Color="#FF000000"/>
    <SolidColorBrush x:Key="AppForeGroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="PanelBackGroundBrush" Color="#FF111111"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#FFFFFFFF"/>
    
    <!--Control Brushes-->
    <SolidColorBrush x:Key="ButtonBackGroundBrush" Color="#FF000000"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FF333333"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#FF666666"/>

    <SolidColorBrush x:Key="ScrollHoverBrush" Color="#FF222222"/>

    <SolidColorBrush x:Key="TextBoxBackgroundBrush" Color="#FF000000"/>
    <SolidColorBrush x:Key="TextBoxHoverBrush" Color="#FF050505"/>

    <SolidColorBrush x:Key="HoverBorderBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="SelectedBorderBrush" Color="#FFAAAAAA"/>

    <!--Graphing Brushes-->
    <SolidColorBrush x:Key="GraphBackGroundBrush" Color="#FF000000"/>
    <SolidColorBrush x:Key="GraphColorPro" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="GraphColorCar" Color="#FFAAAAAA"/>
    <SolidColorBrush x:Key="GraphColorFat" Color="#FF555555"/>
    <SolidColorBrush x:Key="GraphGridBrush" Color="#FFAAAAAA"/>
    <SolidColorBrush x:Key="GraphTrendLineBrush" Color="#FFAAAAAA"/>
    
    <!--DataGrid Brushes-->
    <SolidColorBrush x:Key="GridLineBrush" Color="#FF222222"/>

    <!--Graph Series Parameters-->
    <SolidColorBrush x:Key="LineSeriesBrush1" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="LineSeriesBrush2" Color="#FFFF0000"/>
    <SolidColorBrush x:Key="LineSeriesBrush3" Color="#FF00AAFF"/>

    <SolidColorBrush x:Key="DayBinarySeriesBrush1" Color="#FF00BB00"/>

    <SolidColorBrush x:Key="HighlightBrush1" Color="#FFF1FF00"/>

</ResourceDictionary>