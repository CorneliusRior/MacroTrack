<local:ControlBase x:Class="MacroTrack.AppLibrary.Controls.AddPresetControl"   
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                   xmlns:local="clr-namespace:MacroTrack.AppLibrary.Controls"
                   mc:Ignorable="d" 
                   xmlns:conv="clr-namespace:MacroTrack.AppLibrary.Converters"
                   d:DesignHeight="350" d:DesignWidth="600">
    <local:ControlBase.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullableDoubleConverter x:Key="NullDouble"/>
    </local:ControlBase.Resources>
    <Border Background="{DynamicResource PanelBackGroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Label Content="Add New Preset"
                       Style="{DynamicResource Label.Title}"
                       Grid.Column="0"/>
                <Button x:Name="buttonManage" Content="Manage Presets" 
                        Command="{Binding OpenManageCommand}"
                        Grid.Column="1"/>
            </Grid>
            
            
            
            <!--Content Grid-->
            <Border Margin="5" Grid.Row="1"> <!--This is here for padding or margin &c.-->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!--First Row-->
                    <Label Content="Preset Name:" Grid.Row="0" Grid.Column="0"/>
                    
                    <TextBox x:Name="tbPresetName" 
                             Text="{Binding PresetName}" 
                             MinWidth="200" 
                             Grid.Row="0" Grid.Column="1"/>
                    
                    <Grid Grid.Row="0" Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Label Content="Amount (x1):" 
                               HorizontalAlignment="Right" 
                               Grid.Row="0" Grid.Column="0"/>
                        <TextBox x:Name="tbWeight" 
                                 Text="{Binding Weight}"
                                 Style="{DynamicResource TextBox.Numeric}" 
                                 Grid.Row="0" Grid.Column="1"/>
                        <RadioButton x:Name="rbUnitGram"
                                     GroupName="rbgUnit"
                                     IsChecked="{Binding UnitGram}"
                                     Content="g"
                                     Margin="6,0,4,0"
                                     VerticalAlignment="Center"
                                     Grid.Column="2"/>
                        <RadioButton x:Name="rbUnitMl"
                                     GroupName="rbgUnit"
                                     IsChecked="{Binding UnitMl}"
                                     Content="ml"
                                     Margin="5"
                                     VerticalAlignment="Center"
                                     Grid.Column="3"/>
                    </Grid>
                    
                    <!--Second Row-->
                    <Label Content="Preset Category" Grid.Row="1" Grid.Column="0"/>
                    <ComboBox x:Name="cbCategory" 
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              Template="{DynamicResource MTComboBoxTemplate}"
                              ItemsSource="{Binding CatList}"
                              Text="{Binding Category,
                                     UpdateSourceTrigger=PropertyChanged}"
                              Grid.Row="1" Grid.Column="1"/>
                    
                    <!--Third Row-->
                    <StackPanel Orientation="Horizontal" Grid.Row="2"                                 
                                Grid.Column="0" Grid.ColumnSpan="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Calories (Kcal):" Grid.Column="0"/>
                            <TextBox x:Name="tbCal" 
                                     Text="{Binding Cal, 
                                            Converter={StaticResource NullDouble},
                                            UpdateSourceTrigger=PropertyChanged,
                                            ValidatesOnDataErrors=True}"
                                     Style="{DynamicResource TextBox.Numeric}" 
                                     Grid.Column="1"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Protein (g):" 
                                   Grid.Column="0"/>
                            <TextBox x:Name="tbPro" 
                                     Text="{Binding Pro, 
                                            Converter={StaticResource NullDouble},
                                            UpdateSourceTrigger=PropertyChanged,
                                            ValidatesOnDataErrors=True}"
                                     Style="{DynamicResource TextBox.Numeric}" 
                                     Grid.Column="1"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Carbs (g):" Grid.Column="0"/>
                            <TextBox x:Name="tbCar" 
                                     Text="{Binding Car, 
                                            Converter={StaticResource NullDouble},
                                            UpdateSourceTrigger=PropertyChanged,
                                            ValidatesOnDataErrors=True}"
                                     Style="{DynamicResource TextBox.Numeric}" 
                                     Grid.Column="1"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Fat (g):" Grid.Column="0"/>
                            <TextBox x:Name="tbFat" 
                                     Text="{Binding Fat, 
                                            Converter={StaticResource NullDouble},
                                            UpdateSourceTrigger=PropertyChanged,
                                            ValidatesOnDataErrors=True}"
                                     Style="{DynamicResource TextBox.Numeric}" 
                                     Grid.Column="1"/>
                        </Grid>

                    </StackPanel>

                    <!--Fourth & Fifth Row-->
                    <Label Content="Notes:" Grid.Row="3"/>
                    <TextBox Text="{Binding Notes}" 
                             Style="{DynamicResource TextBox.MultiLine}"                              
                             Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="5"/>


                </Grid>
            </Border>

            <StackPanel Style="{DynamicResource StackPanel.Footer}"
                        Grid.Row="2">
                <Button x:Name="buttonCancel"
                        Content="Cancel"
                        Click="buttonCancel_Click"
                        Visibility="{Binding InWindow, 
                                     RelativeSource={RelativeSource AncestorType=local:AddPresetControl},
                                     Converter={StaticResource BoolToVis}}"/>
                <Button x:Name="buttonClear"
                        Content="Clear"
                        Click="buttonClear_Click"/>
                <Button x:Name="buttonAdd"
                        Content="Add"
                        Click="buttonAdd_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</local:ControlBase>
