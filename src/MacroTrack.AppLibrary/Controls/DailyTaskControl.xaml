<local:ControlBase x:Class="MacroTrack.AppLibrary.Controls.DailyTaskControl"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                   xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
                   xmlns:local="clr-namespace:MacroTrack.AppLibrary.Controls"
                   mc:Ignorable="d" 
                   d:DesignHeight="350" d:DesignWidth="300">
    <local:ControlBase.Resources>
        <!--Try to copy code from HistoryControl.xaml, that kind of structure.-->
        <CollectionViewSource x:Key="SortedTasks" Source="{Binding Tasks}">
            <CollectionViewSource.SortDescriptions>
                <!--We could set "PropertyName" to be set to a DP which we could alter in settings-->
                <scm:SortDescription PropertyName="Name" Direction="Ascending"/>
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
    </local:ControlBase.Resources>
    
    <Border Background="{DynamicResource PanelBackGroundBrush}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Label Content="Daily Tasks" Style="{DynamicResource Label.Title}"
                   Grid.Row="0"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="tbNewTask"
                         Grid.Column="0"/>
                <Button x:Name="buttonNewTask"
                        Content="Add Task"
                        Click="buttonNewTask_Click"
                        Grid.Column="1"/>

            </Grid>
            
            <!--Actual taskitems here-->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          Margin="5"
                          Grid.Row="2">
                <!--Considering formatting this as like a datagrid, so you could do things like-->
                <!--sort by streak length and that sort of thing, rather than being structtly  -->
                <!--alphabetical. Keeping it alphabetical for now, we can always make different-->
                <!--versions of the controls in future and swap them out if needs be           -->

                <ItemsControl x:Name="TaskItems" ItemsSource="{Binding Source={StaticResource SortedTasks}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <local:DailyTaskListItem Task="{Binding}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
            </ScrollViewer>

            <StackPanel Style="{DynamicResource StackPanel.Footer}"
                        Grid.Row="3">
                <Button x:Name="btManageTasks"
                        Content="Manage Tasks"
                        Click="btManageTasks_Click"/>

            </StackPanel>

        </Grid>
        
    </Border>
</local:ControlBase>
