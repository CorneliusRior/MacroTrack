<local:ControlBase x:Class="MacroTrack.AppLibrary.Controls.DailyTaskManageControl"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                   xmlns:conv="clr-namespace:MacroTrack.AppLibrary.Converters"
                   xmlns:local="clr-namespace:MacroTrack.AppLibrary.Controls"
                   mc:Ignorable="d" 
                   d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToCheckedConverter x:Key="BoolToX"/>
    </UserControl.Resources>
    <Border Background="{DynamicResource PanelBackGroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Manage Tasks" Style="{DynamicResource TextBlock.MidTitle}" Grid.Row="0"/>

            <TabControl Margin="5" Grid.Row="1">
                <TabItem Header="Tasks">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="{DynamicResource PanelBackGroundBrush}" 
                                BorderBrush="{DynamicResource BorderBrush}" 
                                BorderThickness="{DynamicResource ButtonBorderThickness}" 
                                Margin="5,5,5,0" 
                                Grid.Row="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Daily Tasks"
                                           Style="{DynamicResource TextBlock.MidTitle}"
                                           IsEnabled="{Binding IsEditing}"/>
                            </StackPanel>
                        </Border>
                        
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="3*"/>
                            </Grid.ColumnDefinitions>

                            <DataGrid RowHeaderStyle="{DynamicResource MTDataGridRowHeaderStyle}"
                                      Template="{DynamicResource MTDataGrid}"
                                      ItemsSource="{Binding TaskList}"  
                                      SelectedItem="{Binding SelectedTask}"
                                      IsReadOnly="True"
                                      CanUserResizeColumns="True"
                                      AutoGenerateColumns="False"
                                      Margin="5,5,0,5"
                                      Grid.Column="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id, StringFormat={}#{0:N0}}" SortMemberPath="Id"/>
                                    <DataGridTextColumn Header="Task" Binding="{Binding Name}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsActive}"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <GridSplitter Grid.Column="1"/>

                            <Border Background="{DynamicResource PanelBackGroundBrush}" 
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="{DynamicResource ButtonBorderThickness}"
                                    Margin="0,5,5,5"
                                    Grid.Column="2">
                                <Border.Resources>
                                    <DataTemplate x:Key="TemplateTaskView">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="auto"/>
                                                <ColumnDefinition Width="auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding SelectedTask.Name, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource TextBlock.MidTitle}"/>
                                            <TextBlock Text="{Binding SelectedTask.Description, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource TextBlock.Base}" Grid.Row="1" Grid.ColumnSpan="2"/>

                                            <CheckBox IsChecked="{Binding SelectedTask.IsActive}" Content="Enabled"
                                                      Visibility="{Binding HasSelected, Converter={StaticResource BoolToVis}}"
                                                      IsHitTestVisible="False" Focusable="False"
                                                      Grid.Row="0" Grid.Column="1"/>

                                            <Button Content="✍️"  Style="{DynamicResource Button.EditButton}"
                                                    Visibility="{Binding HasSelected, Converter={StaticResource BoolToVis}}"
                                                    Command="{Binding OpenEditCommand}"
                                                    Grid.Row="0" Grid.Column="2"/>
                                        </Grid>
                                    </DataTemplate>
                                    <DataTemplate x:Key="TemplateTaskEdit">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBox FontSize="{DynamicResource UITitleSize}" 
                                                     Text="{Binding SelectedEditable.Name}" 
                                                     Margin="5,5,0,0" Grid.Row="0" Grid.Column="0"/>
                                            <TextBox Style="{DynamicResource TextBox.MultiLine}" 
                                                     Text="{Binding SelectedEditable.Description}" 
                                                     Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"/>
                                            <CheckBox Content="Enabled" 
                                                      IsChecked="{Binding SelectedEditable.IsActive}" 
                                                      Margin="10" Grid.Row="0" Grid.Column="1"/>
                                            <StackPanel Style="{DynamicResource StackPanel.Footer}" Grid.Row="2" Grid.ColumnSpan="2">
                                                <Button Content="Cancel" Command="{Binding OpenViewCommand}"/>
                                                <Button Content="Edit" Command="{Binding EditCommand}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </Border.Resources>
                                <ContentControl Content="{Binding}">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Setter Property="ContentTemplate" Value="{StaticResource TemplateTaskView}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource TemplateTaskEdit}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                            </Border>
                        </Grid>
                    </Grid>
                    
                </TabItem>

                <TabItem Header="History">
                    <DataGrid Name="dgHistory"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              CanUserResizeColumns="True"
                              IsReadOnly="True"
                              HeadersVisibility="All"
                              GridLinesVisibility="All"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              Margin="5"/>
                </TabItem>
            </TabControl>
            

            <StackPanel Style="{DynamicResource StackPanel.Footer}" Grid.Row="2">
                <Button Content="Close"
                        Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</local:ControlBase>
